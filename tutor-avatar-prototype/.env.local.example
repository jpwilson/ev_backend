# ===== OpenAI Realtime =====
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# ===== Simli =====
SIMLI_API_KEY=
# Pick a face from https://docs.simli.com/api-reference/faces or upload your own
SIMLI_FACE_ID=tmp9i8bbq7c

# ===== Hedra (via LiveKit) =====
# Get LiveKit creds from https://cloud.livekit.io (or self-host)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Hedra API + character id (used by the worker process in worker/hedra_agent.py)
HEDRA_API_KEY=
HEDRA_CHARACTER_ID=

# ===== Langfuse (optional, leave blank to disable tracing) =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
